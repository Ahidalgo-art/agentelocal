# AgenteLocal backend environment template
# Copy this file to backend/.env and set real values per environment.

# App runtime
HOST=127.0.0.1
PORT=8000
ENVIRONMENT=development
DEBUG=true

# Database
# Required in every environment. Use secret manager/CI secrets outside local.
DATABASE_URL=postgresql+psycopg://user:change_me@localhost:5432/agente_local
DATABASE_ECHO=false

# Google OAuth app (required when using /v1/sync endpoints)
# Create OAuth credentials in Google Cloud Console and set these values.
GOOGLE_CLIENT_ID=change_me
GOOGLE_CLIENT_SECRET=change_me
GOOGLE_PROJECT_ID=change_me
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token

# Optional: local callback used by auth/bootstrap scripts
# GOOGLE_REDIRECT_URI=http://localhost:8080/oauth2/callback
